# ==========================================
# General / VCS / IDE
# ==========================================
.git/
.gitignore
.dockerignore
README.md
LICENSE
.vscode/
.idea/
*.md

# ==========================================
# Docker / Compose (Prevent recursive context)
# ==========================================
docker-compose.yml
docker-compose.override.yml
# Note: Do NOT ignore Dockerfile or entrypoint.sh

# ==========================================
# Django / Python (app/)
# ==========================================
__pycache__/
*.pyc
.venv/
venv/
.env
staticfiles/
app/staticfiles/
app/__pycache__/
app/*.pyc
app/.venv/
app/venv/
app/.env
app/db.sqlite3
app/media/
app/.coverage
app/htmlcov/
app/*.log
app/static/frontend/

# ==========================================
# Frontend / Node.js (frontend/)
# ==========================================
# CRITICAL: Never send node_modules to the Docker build context
node_modules
app/frontend/node_modules/
app/frontend/dist/
app/frontend/build/
app/frontend/.cache/
app/frontend/.env
app/frontend/.env.*

# ==========================================
# Host OS / Misc
# ==========================================
.DS_Store
Thumbs.db